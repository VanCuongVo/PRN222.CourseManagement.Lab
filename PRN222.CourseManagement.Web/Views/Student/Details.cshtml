@model PRN222.CourseManagement.Repository.Models.Student

@{
    ViewData["Title"] = "Student Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-info-circle"></i> Student Details
                    </h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4 fw-bold">Student ID</dt>
                        <dd class="col-sm-8">@Model.StudentId</dd>

                        <dt class="col-sm-4 fw-bold">Student Code</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary">@Model.StudentCode</span>
                        </dd>

                        <dt class="col-sm-4 fw-bold">Full Name</dt>
                        <dd class="col-sm-8">@Model.FullName</dd>

                        <dt class="col-sm-4 fw-bold">Email</dt>
                        <dd class="col-sm-8">
                            <a href="mailto:@Model.Email">@Model.Email</a>
                        </dd>

                        <dt class="col-sm-4 fw-bold">Date of Birth</dt>
                        <dd class="col-sm-8">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4 fw-bold">Age</dt>
                        <dd class="col-sm-8">
                            @{
                                var age = DateTime.Now.Year - Model.DateOfBirth.Year;
                                if (DateTime.Now.DayOfYear < Model.DateOfBirth.DayOfYear)
                                    age--;
                            }
                            @age years old
                        </dd>

                        <dt class="col-sm-4 fw-bold">Department</dt>
                        <dd class="col-sm-8">
                            @if (Model.Department != null)
                            {
                                <span class="badge bg-primary">@Model.Department.Name</span>
                            }
                            else
                            {
                                <span class="text-muted">Not assigned</span>
                            }
                        </dd>

                        <dt class="col-sm-4 fw-bold">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </dd>
                    </dl>

                    @if (Model.Department != null && !string.IsNullOrEmpty(Model.Department.Description))
                    {
                        <div class="alert alert-light border mt-3">
                            <strong>Department Description:</strong>
                            <p class="mb-0 mt-2">@Model.Department.Description</p>
                        </div>
                    }

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.StudentId" class="btn btn-warning">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.StudentId" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>