@model PRN222.CourseManagement.Repository.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-exclamation-triangle"></i> Delete Student
                    </h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <strong>Warning!</strong> Are you sure you want to delete this student? This action cannot be
                        undone!
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4 fw-bold">Student ID</dt>
                        <dd class="col-sm-8">@Model.StudentId</dd>

                        <dt class="col-sm-4 fw-bold">Student Code</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-secondary">@Model.StudentCode</span>
                        </dd>

                        <dt class="col-sm-4 fw-bold">Full Name</dt>
                        <dd class="col-sm-8">@Model.FullName</dd>

                        <dt class="col-sm-4 fw-bold">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4 fw-bold">Date of Birth</dt>
                        <dd class="col-sm-8">@Model.DateOfBirth.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-4 fw-bold">Department</dt>
                        <dd class="col-sm-8">
                            @if (Model.Department != null)
                            {
                                <span class="badge bg-primary">@Model.Department.Name</span>
                            }
                            else
                            {
                                <span class="text-muted">Not assigned</span>
                            }
                        </dd>

                        <dt class="col-sm-4 fw-bold">Status</dt>
                        <dd class="col-sm-8">
                            <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </span>
                        </dd>
                    </dl>

                    <form asp-action="Delete" method="post" class="mt-4">
                        <input type="hidden" asp-for="StudentId" />
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Confirm Delete
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>