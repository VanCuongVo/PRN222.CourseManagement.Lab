@model IEnumerable<PRN222.CourseManagement.Repository.Models.Student>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Student List</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Student
        </a>
    </div>

    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Student Code</th>
                <th>Date of Birth</th>
                <th>Full Name</th>
                <th>Status</th>
                <th>Department</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>@s.StudentId</td>
                    <td>@s.StudentCode</td>
                    <td>@s.DateOfBirth.ToString("dd/MM/yyyy")</td>
                    <td>@s.FullName</td>
                    <td>
                        <span class="badge @(s.IsActive == true ? "bg-success" : "bg-danger")">
                            @(s.IsActive == true ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>@s.DepartmentId</td>
                    <td class="text-center">
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" asp-route-id="@s.StudentId" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>

                            <a asp-action="Details" asp-route-id="@s.StudentId" class="btn btn-info btn-sm">
                                <i class="bi bi-info-circle"></i> Details
                            </a>

                            <a asp-action="Delete" asp-route-id="@s.StudentId" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>